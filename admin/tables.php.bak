<?php 
include 'auth.php';
include 'db.php'; // Include your database connection

if (isset($_GET['delete_event'])) {
    $event_id = intval($_GET['delete_event']);
    $delete_event_query = "DELETE FROM events WHERE id = ?";
    $stmt = mysqli_prepare($conn, $delete_event_query);
    mysqli_stmt_bind_param($stmt, 'i', $event_id);
    mysqli_stmt_execute($stmt);
    mysqli_stmt_close($stmt);
    header("Location: tables.php"); // Redirect to avoid resubmission
    exit();
}
// Query to fetch booked orders
$query = "SELECT * FROM booking ORDER BY id DESC"; 
$result = mysqli_query($conn, $query);

$query = "SELECT * FROM events ORDER BY id DESC"; 
$res = mysqli_query($conn, $query);

